POSTGRES_PASSWORD=change-this-postgres-password

SECRET_KEY=change-this-to-a-long-random-secret-at-least-32-chars

STORAGE_BACKEND=local
ECG_DATA_DIR=./data
ECG_STORAGE_DIR=./data/storage

